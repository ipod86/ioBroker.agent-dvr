{
    "i18n": true,
    "type": "tabs",
    "items": {
        "tabConnection": {
            "type": "panel",
            "label": "tabConnection",
            "items": {
                "ip": {
                    "type": "text",
                    "label": "cfgIp",
                    "newLine": true,
                    "xs": 12, "sm": 12, "md": 6, "lg": 4, "xl": 4
                },
                "port": {
                    "type": "number",
                    "label": "cfgPort",
                    "min": 1,
                    "max": 65535,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "user": {
                    "type": "text",
                    "label": "cfgUser",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "pass": {
                    "type": "password",
                    "label": "cfgPass",
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "pollSeconds": {
                    "type": "number",
                    "label": "cfgPollSeconds",
                    "min": 5,
                    "max": 3600,
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "httpTimeoutMs": {
                    "type": "number",
                    "label": "cfgHttpTimeoutMs",
                    "min": 1000,
                    "max": 30000,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                }
            }
        },
        "tabFeatures": {
            "type": "panel",
            "label": "tabFeatures",
            "items": {
                "hdrControls": {
                    "type": "header",
                    "text": "hdrControls",
                    "newLine": true,
                    "xs": 12
                },
                "enableSystemControls": {
                    "type": "checkbox",
                    "label": "cfgEnableSystemControls",
                    "help": "cfgEnableSystemControls_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "enablePtz": {
                    "type": "checkbox",
                    "label": "cfgEnablePtz",
                    "help": "cfgEnablePtz_tt",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "enableUrls": {
                    "type": "checkbox",
                    "label": "cfgEnableUrls",
                    "help": "cfgEnableUrls_tt",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "enableSnapshotB64": {
                    "type": "checkbox",
                    "label": "cfgEnableSnapshotB64",
                    "help": "cfgEnableSnapshotB64_tt",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "hdrEvents": {
                    "type": "header",
                    "text": "hdrEvents",
                    "newLine": true,
                    "xs": 12
                },
                "enableEventDps": {
                    "type": "checkbox",
                    "label": "cfgEnableEventDps",
                    "help": "cfgEnableEventDps_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "enablePush": {
                    "type": "checkbox",
                    "label": "cfgEnablePush",
                    "help": "cfgEnablePush_tt",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "hdrDisplay": {
                    "type": "header",
                    "text": "hdrDisplay",
                    "newLine": true,
                    "xs": 12
                },
                "enableOverview": {
                    "type": "checkbox",
                    "label": "cfgEnableOverview",
                    "help": "cfgEnableOverview_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "hdrDebug": {
                    "type": "header",
                    "text": "hdrDebug",
                    "newLine": true,
                    "xs": 12
                },
                "storeRawJson": {
                    "type": "checkbox",
                    "label": "cfgStoreRawJson",
                    "help": "cfgStoreRawJson_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                }
            }
        },
        "tabWidget": {
            "type": "panel",
            "label": "tabWidget",
            "items": {
                "hdrWidgetGeneral": {
                    "type": "header",
                    "text": "hdrWidgetGeneral",
                    "newLine": true,
                    "xs": 12
                },
                "enableWidget": {
                    "type": "checkbox",
                    "label": "cfgEnableWidget",
                    "help": "cfgEnableWidget_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "widgetMode": {
                    "type": "select",
                    "label": "cfgWidgetMode",
                    "help": "cfgWidgetMode_tt",
                    "options": [
                        { "value": "nojs", "label": "cfgWidgetModeNojs" },
                        { "value": "js",   "label": "cfgWidgetModeJs" }
                    ],
                    "xs": 12, "sm": 6, "md": 6, "lg": 5, "xl": 5
                },
                "hdrWidgetLayout": {
                    "type": "header",
                    "text": "hdrWidgetLayout",
                    "newLine": true,
                    "xs": 12
                },
                "widgetAnzahl": {
                    "type": "number",
                    "label": "cfgWidgetAnzahl",
                    "help": "cfgWidgetAnzahl_tt",
                    "min": 1,
                    "max": 500,
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "widgetMinCol": {
                    "type": "number",
                    "label": "cfgWidgetMinCol",
                    "help": "cfgWidgetMinCol_tt",
                    "min": 80,
                    "max": 600,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "widgetMaxModalWidth": {
                    "type": "number",
                    "label": "cfgWidgetMaxModalWidth",
                    "help": "cfgWidgetMaxModalWidth_tt",
                    "min": 300,
                    "max": 2000,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "hdrWidgetTags": {
                    "type": "header",
                    "text": "hdrWidgetTags",
                    "newLine": true,
                    "xs": 12
                },
                "widgetShowTags": {
                    "type": "checkbox",
                    "label": "cfgWidgetShowTags",
                    "help": "cfgWidgetShowTags_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "widgetTagPosition": {
                    "type": "select",
                    "label": "cfgWidgetTagPosition",
                    "help": "cfgWidgetTagPosition_tt",
                    "options": [
                        { "value": "top-left",     "label": "cfgTagPosTopLeft" },
                        { "value": "top-right",    "label": "cfgTagPosTopRight" },
                        { "value": "bottom-left",  "label": "cfgTagPosBotLeft" },
                        { "value": "bottom-right", "label": "cfgTagPosBotRight" }
                    ],
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "hdrWidgetPlayer": {
                    "type": "header",
                    "text": "hdrWidgetPlayer",
                    "newLine": true,
                    "xs": 12
                },
                "widgetLiveAspect": {
                    "type": "text",
                    "label": "cfgWidgetLiveAspect",
                    "help": "cfgWidgetLiveAspect_tt",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "widgetPlayerUrl": {
                    "type": "text",
                    "label": "cfgWidgetPlayerUrl",
                    "help": "cfgWidgetPlayerUrl_tt",
                    "newLine": true,
                    "xs": 12, "sm": 12, "md": 8, "lg": 8, "xl": 8
                }
            }
        },
        "tabAdvanced": {
            "type": "panel",
            "label": "tabAdvanced",
            "items": {
                "maxDepth": {
                    "type": "number",
                    "label": "cfgMaxDepth",
                    "min": 1,
                    "max": 10,
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "maxArray": {
                    "type": "number",
                    "label": "cfgMaxArray",
                    "min": 1,
                    "max": 500,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "eventTagsDynamic": {
                    "type": "checkbox",
                    "label": "cfgEventTagsDynamic",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "eventTagsIgnore": {
                    "type": "text",
                    "label": "cfgEventTagsIgnore",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 6, "lg": 4, "xl": 4
                },
                "eventTags": {
                    "type": "text",
                    "label": "cfgEventTags",
                    "xs": 12, "sm": 6, "md": 6, "lg": 4, "xl": 4
                }
            }
        }
    }
}
