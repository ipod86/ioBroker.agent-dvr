{
    "i18n": true,
    "type": "tabs",
    "items": {
        "tabConnection": {
            "type": "panel",
            "label": "tabConnection",
            "items": {
                "ip": {
                    "type": "text",
                    "label": "cfgIp",
                    "newLine": true,
                    "xs": 12, "sm": 12, "md": 6, "lg": 4, "xl": 4
                },
                "port": {
                    "type": "number",
                    "label": "cfgPort",
                    "min": 1,
                    "max": 65535,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "user": {
                    "type": "text",
                    "label": "cfgUser",
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "pass": {
                    "type": "password",
                    "label": "cfgPass",
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "pollSeconds": {
                    "type": "number",
                    "label": "cfgPollSeconds",
                    "min": 5,
                    "max": 3600,
                    "newLine": true,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "httpTimeoutMs": {
                    "type": "number",
                    "label": "cfgHttpTimeoutMs",
                    "min": 1000,
                    "max": 30000,
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                }
            }
        },
